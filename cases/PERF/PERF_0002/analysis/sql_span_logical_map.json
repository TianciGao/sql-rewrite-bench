        "logical_operator_ids": [
          "positive_sort"
        ],
        "semantic_role": "stable_result_ordering"
      },
      {
        "span_id": "positive_limit",
        "span_text": "LIMIT 100",
        "logical_operator_ids": [
          "positive_limit"
        ],
        "semantic_role": "top_n_limit"
      }
    ],
    "rewrite_neg_01.sql": [
