      "sql_files": [
        "source.sql",
        "rewrite_pos_01.sql",
        "rewrite_neg_01.sql"
      ],
      "span_text": "WHERE d_month_seq IN (1212,1213,1214,1215,1216,1217,1218,1219,1220,1221,1222,1223)\n    AND (\n      (\n        i_category IN ('Books','Children','Electronics')\n        AND i_class IN ('personal','portable','reference','self-help')\n        AND i_brand IN (\n          'scholaramalgamalg #14',\n          'scholaramalgamalg #7',\n          'exportiunivamalg #9',\n          'scholaramalgamalg #9'\n        )\n      )\n      OR\n      (\n        i_category IN ('Women','Music','Men')\n        AND i_class IN ('accessories','classical','fragrances','pants')\n        AND i_brand IN (\n          'amalgimporto #1',\n          'edu packscholar #1',\n          'exportiimporto #1',\n          'importoamalg #1'\n        )\n      )\n    )",
      "logical_operator_ids": [
        "filter_seed_slice"
      ]
    },
    {
      "span_id": "shared_sales_aggregate",
      "sql_files": [
        "source.sql",
        "rewrite_pos_01.sql",
        "rewrite_neg_01.sql"
      ],
      "span_text": "i_manufact_id,\n    SUM(ss_sales_price) AS sum_sales",
      "logical_operator_ids": [
        "aggregate_quarter_sales"
      ]
    },
    {
      "span_id": "shared_group_by",
      "sql_files": [
        "source.sql",
        "rewrite_pos_01.sql",
        "rewrite_neg_01.sql"
      ],
      "span_text": "GROUP BY i_manufact_id, d_qoy",
