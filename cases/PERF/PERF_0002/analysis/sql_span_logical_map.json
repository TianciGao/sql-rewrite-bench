      "sql_files": [
        "source.sql",
        "rewrite_pos_01.sql",
        "rewrite_neg_01.sql"
      ],
      "span_text": "AVG(SUM(ss_sales_price)) OVER (PARTITION BY i_manufact_id) AS avg_quarterly_sales",
      "logical_operator_ids": [
        "window_avg_quarterly_sales"
      ]
    }
  ],
  "query_spans": {
    "source.sql": [
      {
        "span_id": "source_outer_filter_ratio_guard",
        "span_text": "WHERE CASE\n        WHEN avg_quarterly_sales > 0\n          THEN ABS(sum_sales - avg_quarterly_sales) / avg_quarterly_sales\n        ELSE NULL\n      END > 0.1",
